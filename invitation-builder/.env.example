NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Postgres (Prisma)
DATABASE_URL=
DIRECT_URL=
# 네이버 클라우드 플랫폼 — 동일 앱에서 Maps + Geocoding API 사용 권장
# https://www.ncloud.com/ → AI·NAVER API → Application 등록
# 이 파일을 복사해 .env.local 로 저장한 뒤 값만 채우면 됩니다.
NEXT_PUBLIC_NAVER_MAPS_CLIENT_ID=
# 오시는 길 미리보기: 서버가 네이버 Static Map API로 이미지를 받음 → NCP에서 Static Map 사용 ON 필수.
# (브라우저 JS 지도는 Web 서비스 URL 제약이 있어, 미리보기는 정적 지도로 통일했습니다.)
# 지오코딩(주소→좌표) — 서버 전용. 미리보기 지도 핀 위치 정확도 향상
NAVER_MAPS_CLIENT_SECRET=
# (선택) 공개 Client ID와 다른 키 ID를 쓸 때만 설정. 비우면 NEXT_PUBLIC_NAVER_MAPS_CLIENT_ID 사용
# NAVER_MAPS_API_KEY_ID=
